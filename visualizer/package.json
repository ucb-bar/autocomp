{
  "name": "autocomp-visualizer",
  "displayName": "Autocomp Trace Visualizer",
  "description": "Visualize beam search optimization traces from Autocomp — interactive score charts, beam trees, code diffs, and plan summaries.",
  "version": "0.2.10",
  "publisher": "charleshong3",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "https://github.com/ucb-bar/autocomp",
    "directory": "visualizer"
  },
  "homepage": "https://github.com/ucb-bar/autocomp/tree/main/visualizer#readme",
  "bugs": {
    "url": "https://github.com/ucb-bar/autocomp/issues"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Data Science"
  ],
  "keywords": [
    "autocomp",
    "beam search",
    "optimization",
    "trace",
    "visualizer"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "autocomp.openTraces",
        "title": "Autocomp: Open Trace Visualizer"
      }
    ]
  },
  "scripts": {
    "build:webview": "vite build",
    "build:ext": "esbuild src/extension/extension.ts --bundle --platform=node --external:vscode --outfile=dist/extension.js --sourcemap",
    "build": "npm run build:webview && npm run build:ext",
    "watch:webview": "vite build --watch",
    "watch:ext": "esbuild src/extension/extension.ts --bundle --platform=node --external:vscode --outfile=dist/extension.js --sourcemap --watch",
    "watch": "concurrently \"npm run watch:webview\" \"npm run watch:ext\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "npm run build && vsce package"
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vscode/vsce": "^3.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "esbuild": "^0.24.0",
    "postcss": "^8.4.49",
    "react": "^18",
    "react-dom": "^18",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vite": "^6.0.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1023.0",
    "google-auth-library": "^10.6.2",
    "openai": "^6.33.0"
  }
}
