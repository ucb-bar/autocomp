{
  "name": "autocomp-visualizer",
  "displayName": "Autocomp Trace Visualizer",
  "description": "Visualize Autocomp beam search optimization traces",
  "version": "0.1.0",
  "publisher": "autocomp",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Visualization"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "autocomp.openTraces",
        "title": "Autocomp: Open Traces"
      },
      {
        "command": "autocomp.ingestAndOpen",
        "title": "Autocomp: Ingest & Open Traces"
      }
    ]
  },
  "scripts": {
    "build:webview": "vite build",
    "build:ext": "esbuild src/extension/extension.ts --bundle --platform=node --external:vscode --outfile=dist/extension.js --sourcemap",
    "build": "npm run build:webview && npm run build:ext",
    "watch:webview": "vite build --watch",
    "watch:ext": "esbuild src/extension/extension.ts --bundle --platform=node --external:vscode --outfile=dist/extension.js --sourcemap --watch",
    "watch": "concurrently \"npm run watch:webview\" \"npm run watch:ext\"",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/vscode": "^1.85.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "esbuild": "^0.24.0",
    "postcss": "^8.4.49",
    "react": "^18",
    "react-dom": "^18",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vite": "^6.0.0"
  }
}
